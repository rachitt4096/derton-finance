# Preferred: Derton backend base URL. When set, the app uses backend auth,
# backend WebSocket market snapshots, and stored market history for charts.
VITE_BACKEND_URL=http://localhost:4000

# Optional explicit WebSocket URL. Leave empty to derive from VITE_BACKEND_URL.
VITE_BACKEND_WS_URL=

# Production note:
# This app is intended to run against the Derton backend via VITE_BACKEND_URL.
# Do not rely on alternate stock-API fallbacks for production.
