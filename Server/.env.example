NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_ORIGIN=http://localhost:5173,http://localhost:5174
COOKIE_NAME=derton_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
SESSION_TTL_HOURS=168
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/derton_finance
BROKER_MODE=upstox
MARKET_SNAPSHOT_MS=500
MARKET_FLUSH_MS=1000
MARKET_HISTORY_RETENTION_DAYS=90
MARKET_CANDLE_RETENTION_DAYS=365
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_AUTH_URL=https://api.upstox.com/v2/login/authorization/dialog
UPSTOX_TOKEN_URL=https://api.upstox.com/v2/login/authorization/token
# Analytics Token (recommended for analysis-only use): 1-year read-only token
# generated at account.upstox.com/developer/apps -> Analytics tab.
# No OAuth/daily refresh needed. Used as the Bearer token for all market data.
UPSTOX_ACCESS_TOKEN=
# Below only needed for the interactive daily OAuth flow (not used with Analytics Token):
UPSTOX_USER_ID=
UPSTOX_PIN=
UPSTOX_TOTP_SECRET=
UPSTOX_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz

# --- AI Assistant (floating chatbot) ---
# Reasoning runs on AWS Bedrock. Set a model you have enabled in your Bedrock
# account (Claude models recommended; there is no "k2.5" on Bedrock).
AI_ENABLED=false
AWS_REGION=ap-south-1
BEDROCK_REGION=
BEDROCK_MODEL_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Web search for the news/insights tool (https://tavily.com)
TAVILY_API_KEY=

SEED_ADMIN_EMAIL=admin@derton.local
SEED_ADMIN_PASSWORD=admin@2026
ALLOW_DEFAULT_ADMIN_PASSWORD=true

# External alerting (stale feed / watchdog restart threshold / restart failures)
ALERTS_ENABLED=false
ALERT_COOLDOWN_MS=300000

# Slack Incoming Webhook
ALERT_SLACK_WEBHOOK_URL=

# WhatsApp via Twilio
ALERT_WHATSAPP_TWILIO_ACCOUNT_SID=
ALERT_WHATSAPP_TWILIO_AUTH_TOKEN=
ALERT_WHATSAPP_TWILIO_FROM=
ALERT_WHATSAPP_TWILIO_TO=

# Email webhook (route to your email provider/automation)
ALERT_EMAIL_WEBHOOK_URL=
ALERT_EMAIL_WEBHOOK_TOKEN=
ALERT_EMAIL_FROM=alerts@derton.local
ALERT_EMAIL_TO=ops@example.com
